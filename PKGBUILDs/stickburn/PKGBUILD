#!/bin/bash
# Maintainer: manuel (see forum.endeavouros.com)

pkgname=stickburn
pkgdesc="GUI for burning ISO to USB stick with dd and safety checks."
url="https://github.com/manuel-192/m-m/raw/master/PKGBUILDs/$pkgname"
pkgver=26.2.1
pkgrel=1
arch=('any')
license=('GPL')
depends=(
    bash
    yad        # yad needed only by stickburn
)

source=(
    $pkgname           # GUI burning app
    $pkgname.desktop
    burn2dev
    find-usb-sticks
    iso-to-usb         # CLI burning app
)
sha512sums=('4a0207283c4930df0ba272d08aa558b826650f7ae5143017dc4a27b2b989d45ef79fd4f183f36803e1710d26c16533bc84360fc47e291cb34346ed6e83f356a0'
            'c2932968c88963bedc923f2889cf44b114f4929d1ebfc2678655bb7e3b75a16d740e0f5276633b4233159ac304669aebb1204c6a30ebfeab02de7cdaab1515fa'
            'e625c61067602578dbdb83f59f355d06ef8dc453a86a7d2038bc6665a1c88ce6b1950d5d7bd1c3940bf53a4049a00dd89fb8f3892242c619606a9d40c226bd3a'
            '67a5b1a56eca9773d080a8969dd98bb2db310ef57f7cff2aeebce67ae1a8b034ed8b3b37a988a93cfcaa6316cfa35ae1929b4f00bbda327fecd4c6bae2320589'
            '27a4dadab2da0d2418afabf0a14cac00bc15463cd3d2404ceaf03440fc935343298cc30d22782b9469b959af41da97c3ae2af561c9d23c00a50688c0dfcc5542')

package() {
    local src
    for src in "${source[@]}" ; do
        case "$src" in
            *.desktop) install -Dm644 $src        $pkgdir/usr/share/applications/$src ;;
            *)         install -Dm755 $src        $pkgdir/usr/bin/$src ;;
        esac
    done
}
