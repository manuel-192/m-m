#!/bin/bash

echo2()   { echo -e "$@" >&2; }
warning() { echo2 "$progname: $FUNCNAME: $1" ; }
error()   { echo2 "$progname: $FUNCNAME: $1" ; exit 1; }

BuildRepo() {
    local reponame="$1"
    [ $aur_src = local ] && fetch-aur-stuff $reponame
    assets.make ${options[*]} $pkgs_given
}
export -f BuildRepo

Banner() {
    local tool="$1"
    local extra="$2"
    local line="${tool%% *}"
    [ "$extra" ] && line+=" $extra"
    Color info
    printf "======== %s ========\n" "$line" >&2
    Color
    $tool $extra
}
BannerIf() {
    local -r tool="$1"
    type "${tool%% *}" &>/dev/null && Banner "$tool"
}
Bannered() {
    local -r dir="$1"
    local -r tool="$2"
    local -r extra="$3"
    cd "$dir"
    Banner $tool $extra
    cd "$curdir"
}

AurSource() {
    # Use AUR if possible, otherwise use local copies from the backup repo.
    local -n _refvar="$1"
    /bin/curl --fail-early -Lsm 5 https://aur.archlinux.org >/dev/null  &&  _refvar=aur  ||  _refvar=local
}

IsEosRepo() { printf "%s\n" "${known_reponames_eos[@]}" | grep "^$1$" >/dev/null ; }
IsManRepo() { printf "%s\n" "${known_reponames_m[@]}"   | grep "^$1$" >/dev/null ; }
IsForRepo() { IsEosRepo "$1" || IsManRepo "$1" ; }

Help() {
    cat <<EOF
Usage:       $progname [options] reponames
             $progname [options] reponame [packagenames]

Options:     Options for assets.make.
Reponame:    A local repository name.
Packagename: A package name.

Note: $progname allows giving package names after *one* reponame without
      using option --pkgnames.

~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

EOF
    assets.make --help
}

Main() {
    local progname=${0##*/}
    local known_reponames_eos=(endeavouros endeavouros-testing-dev)
    local known_reponames_m=(m-aur2 m-more2 m-m)
    #local known_othernames=(MAN EOS local-repo)
    local reponame
    local curdir="$PWD"
    local options=(--fetch-timeout=120 -T=0)
    local reponames_given=()
    local pkgs_given=""
    local arg
    local buildmode="--dryrun"
    local aur_src=aur

    # AurSource aur_src

    [ "$CODEDIR" ] || error "CODEDIR is not set"

    for arg in "$@" ; do
        case "$arg" in
            -h | --help) Help; exit 0 ;;
            -b | --build)                                     buildmode="" ;;
            -n | -nl | -nn | -nr | --dryrun | --dryrun-local) buildmode="$arg" ;;
            --aursrc=*) aur_src=${arg#*=}; options+=("$arg") ;;
            -*) options+=("$arg") ;;
            *)
                case "$arg" in
                    MAN | EOS | local-repo)
                        reponames_given+=("$arg")
                        ;;
                    *)
                        if IsForRepo "$arg" ; then
                            reponames_given+=("$arg")
                        else
                            pkgs_given+="$arg,"               # give only one repo if pkgs are given!
                        fi
                        ;;
                esac
                ;;
        esac
    done
    if [ "$pkgs_given" ] ; then
        if [ ${#reponames_given[@]} -ne 1 ] ; then
            error "give exactly one reponame if you give packages too!"
        fi
        pkgs_given=${pkgs_given:: -1}                # remove trailing comma
        pkgs_given="--pkgnames=$pkgs_given"
    fi
    if [ -z "$reponames_given" ] ; then
        # current folder may be the right place to run!
        arg="$( printf "%s\n" "${known_reponames_m[@]}" "${known_reponames_eos[@]}" | grep "^${PWD##*/}$" )"
        if [ "$arg" ] ; then
            reponames_given=("$arg")
        else
            error "give reponame(s)"
        fi
    fi
    [ "$buildmode" ] && options+=("${buildmode}")

    for reponame in "${reponames_given[@]}" ; do
        if IsEosRepo "$reponame" ; then
            Bannered "$CODEDIR/EOS/_BUILD_/$reponame" BuildRepo $reponame
        elif IsManRepo "$reponame" ; then
            Bannered "$CODEDIR/MAN/_BUILD_/$reponame" BuildRepo $reponame
        else
            case "$reponame" in
                MAN | EOS)
                    case "$reponame" in
                        MAN) BannerIf cookbook
                             BannerIf arch-audit
                             [ -x /bin/gh ] && BannerIf "pull-requests -m"
                             ;;
                        EOS) [ -x /bin/gh ] && BannerIf "pull-requests -e"
                             ;;
                    esac
                    Bannered "$CODEDIR/$reponame" UpdateSources "$reponame"
                    ;;
                local-repo)
                    BannerIf local-repo-manager
                    ;;
                *)
                    warning "'$reponame' is not a known repo/src name"
                    ;;
            esac
        fi
    done
}

Main "$@"
