#!/bin/bash

# Maintainer: manuel (see forum.endeavouros.com)

pkgname=gitcl
pkgdesc="Customizable bash completion for 'git clone'"
url="https://github.com/manuel-192/m-m/raw/master/PKGBUILDs/$pkgname"
pkgver=26
pkgrel=1

arch=(any)
license=(GPL)
depends=(git)
backup=(etc/gitcl.conf)

source=(
    $url/gitcl
    $url/gitcl.bash-completion
    $url/gitcl.conf
)
sha512sums=('5eb74f63de28f8a27b83c15db2df448675449e4766dbcc0197af1b947808e88a86be6e4316a38c428c06703c8fe0602e9b0e3259beb99143ff49f44316b241ab'
            '5f458c8f233df5017337b825d312d4b3a6b174412983fb02f8503288e3d00174c32aa7c75a3691c6b72dad564127508ef6eda3d935182f1168b4d49e7eb7c39c'
            'd66c7d770744407ec84e0b76a8ea27e5792009e7090839c15a00730659e3d096616af32482a9f4fb5fa45f0c5cb65779defe764b6b785c417a55b1e61ee5cebf')

package() {
    local item
    for item in "${source[@]}" ; do
        item=${item##*/}
        case "$item" in
            *.conf)             install -Dm644 $item      $pkgdir/etc/$item ;;
            *.bash-completion)  install -Dm644 $item      $pkgdir/usr/share/bash-completion/completions/${item%.*} ;;
            *)                  install -Dm755 $item      $pkgdir/usr/local/bin/$item ;;
        esac
    done
}
